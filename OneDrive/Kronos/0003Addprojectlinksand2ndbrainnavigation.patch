From: Claude <noreply@anthropic.com>
Date: Fri, 10 Jul 2026 21:39:55 +0000
Subject: [PATCH 3/3] Add project links and 2nd brain navigation

Features:
- Add 2nd brain link button in dashboard header
- Add project-specific URLs to each project card
- Add 'View Project' button linking to each project
- Add .env.example for configuration
- Update mobile styling for new header layout
- Link supports external URLs (GitHub, live sites, docs)

Configuration:
- Set NEXT_PUBLIC_BRAIN_URL in .env.local to add 2nd brain link
- Add project_url field to each project in database

Co-Authored-By: Claude Haiku 4.5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01TKtmkHcK18nUqFd7AvWCfY
---
 .env.example                       |  7 ++++
 app/components/ProjectCard.js      |  6 +++
 app/components/ProjectDashboard.js |  7 +++-
 app/page.js                        |  5 +++
 app/styles/dashboard.css           | 62 +++++++++++++++++++++++++++++-
 5 files changed, 85 insertions(+), 2 deletions(-)
 create mode 100644 .env.example

diff --git a/.env.example b/.env.example
new file mode 100644
index 0000000..68a3819
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,7 @@
+# Supabase Configuration
+SUPABASE_URL=your_supabase_url
+SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
+
+# 2nd Brain Link
+# Add your 2nd brain Netlify URL here
+NEXT_PUBLIC_BRAIN_URL=https://your-2nd-brain.netlify.app
diff --git a/app/components/ProjectCard.js b/app/components/ProjectCard.js
index 5de62fe..43a59cb 100644
--- a/app/components/ProjectCard.js
+++ b/app/components/ProjectCard.js
@@ -62,6 +62,12 @@ export default function ProjectCard({ project, isExpanded, onToggleExpand }) {
 
       <p className="project-description">{project.description}</p>
 
+      {project.project_url && (
+        <a href={project.project_url} target="_blank" rel="noopener noreferrer" className="project-link">
+          View Project →
+        </a>
+      )}
+
       <div className="progress-section">
         <div className="progress-header">
           <span className="progress-label">Overall Progress</span>
diff --git a/app/components/ProjectDashboard.js b/app/components/ProjectDashboard.js
index 8e52375..0b74981 100644
--- a/app/components/ProjectDashboard.js
+++ b/app/components/ProjectDashboard.js
@@ -61,7 +61,12 @@ export default function ProjectDashboard({ projects, loading, error }) {
     <div className="dashboard-container">
       <header className="dashboard-header">
         <div className="header-content">
-          <h1>Project Dashboard</h1>
+          <div className="header-top">
+            <h1>Project Dashboard</h1>
+            <a href={process.env.NEXT_PUBLIC_BRAIN_URL || "#"} target="_blank" rel="noopener noreferrer" className="brain-link">
+              📚 2nd Brain
+            </a>
+          </div>
           <p>Track your projects and stay on top of deadlines</p>
         </div>
       </header>
