# ─────────────────────────────────────────────────────────────────────────────
# Atlas configuration. Copy to `.env` and fill in. NEVER commit the real .env.
# Treat every value below like a password.
# ─────────────────────────────────────────────────────────────────────────────

# --- cortextOS / org -------------------------------------------------------
ATLAS_ORG=atlas
# Where cortextOS keeps its state (bus, memory, KB). Defaults under the repo.
CORTEXTOS_HOME=./.cortextos

# --- Model -----------------------------------------------------------------
# The orchestrator + specialists run on Claude Code (uses your `claude login`).
# This is only used by the voice gateway for lightweight turn shaping if enabled.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Voice: Speech-to-Text -------------------------------------------------
# Options: deepgram | whisper-local | openai
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
# For whisper-local, point at a running whisper.cpp / faster-whisper endpoint:
WHISPER_ENDPOINT=http://127.0.0.1:9000

# --- Voice: Text-to-Speech -------------------------------------------------
# Options: elevenlabs | cartesia | openai
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Voice: Transport ------------------------------------------------------
# Options: browser | twilio
VOICE_TRANSPORT=browser
VOICE_PORT=5111
# Hands-free wake word — say it to start a turn without tapping the mic.
# Leave empty to disable hands-free (push-to-talk only).
WAKE_WORD=Atlas

# --- Twilio (only if VOICE_TRANSPORT=twilio) -------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public URL Twilio can reach (e.g. an ngrok / tunnel URL to VOICE_PORT):
VOICE_PUBLIC_URL=

# --- Optional text fallback channel (Telegram) -----------------------------
# One bot per agent if you want text as well as voice. Optional.
BOT_TOKEN=
CHAT_ID=
ALLOWED_USER=
