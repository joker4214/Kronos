import { supabase } from "../../lib/supabase.js";
import { generateContentIdeas, generateCaption } from "../../lib/claude.js";

export default async function handler(req, res) {
  try {
    const agencyId = process.env.AGENCY_ID;

    // Get agency brand voice
    const { data: agency } = await supabase
      .from("agencies")
      .select("brand_voice")
      .eq("id", agencyId)
      .single();

    if (!agency) {
      return res.status(404).json({ error: "Agency not found" });
    }

    // Generate content ideas
    const ideas = await generateContentIdeas(
      agencyId,
      agency.brand_voice
    );

    // For each idea, generate caption and store
    for (const idea of ideas) {
      const caption = await generateCaption(idea.idea, agency.brand_voice);

      // Store idea
      await supabase.from("content_ideas").insert([
        {
          agency_id: agencyId,
          idea: idea.idea,
          type: idea.type,
          status: "draft",
        },
      ]);

      // Store post
      await supabase.from("posts").insert([
        {
          agency_id: agencyId,
          platform: "instagram",
          caption: caption,
          copy: idea.description,
          status: "draft",
        },
      ]);
    }

    res.status(200).json({
      success: true,
      ideas_generated: ideas.length,
    });
  } catch (error) {
    console.error("Error:", error);
    res.status(500).json({ error: error.message });
  }
}
